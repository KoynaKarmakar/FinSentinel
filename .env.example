# FinSentinel Environment Configuration
# Copy this file to .env and fill in your actual values

# Required: Groq API Key
# Get yours free at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: Override the default Groq model
# Available fast models on Groq:
#   llama-3.3-70b-versatile   (default — best quality, ~300 tok/s)
#   llama-3.1-8b-instant      (fastest — good for dev/testing)
#   mixtral-8x7b-32768        (large context window)
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Override other defaults
# CHUNK_SIZE=500
# CHUNK_OVERLAP=50
# TOP_K=10
# RERANK_TOP_N=3
# SQLITE_DB_PATH=finsentinel.db
# BM25_PICKLE_PATH=data/bm25.pkl
